---
import { HEADER_LINKS } from "../../consts";
const path = Astro.url.pathname;
---

<header class="t-header">
  <div class="t-bar">
    <a href="/" class="t-brand"><span class="t-brand-block">▌</span>francesco<span class="t-brand-accent">.</span>esposito</a>
    <nav class="t-nav" aria-label="Primary">
      {HEADER_LINKS.map((t) => {
        const isActive = path === t.url || (t.url !== "/" && path.startsWith(t.url));
        return (
          <a href={t.url} class={`t-nav-link ${isActive ? "is-active" : ""}`} aria-current={isActive ? "page" : undefined}>
            {t.name.toLowerCase()}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<style>
  .t-header { position: sticky; top: 0; z-index: 50; background: var(--bg); border-bottom: 1px solid var(--line); }
  .t-bar {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    max-width: 1280px; margin: 0 auto; padding: 14px 24px;
  }
  .t-brand {
    font-family: var(--mono); font-size: 14px; color: var(--ink); text-decoration: none;
    letter-spacing: 0.01em; white-space: nowrap;
  }
  .t-brand-block { color: var(--accent); margin-right: 6px; animation: t-blink 1.2s steps(1) infinite; }
  .t-brand-accent { color: var(--accent); }
  @keyframes t-blink { 50% { opacity: 0.25; } }
  .t-nav { display: flex; gap: 2px; flex-wrap: wrap; }
  .t-nav-link {
    font-family: var(--mono); font-size: 13px; color: var(--ink-2);
    padding: 4px 8px; text-decoration: none;
    transition: color .15s, background .15s;
  }
  /* brackets always present (reserve space) — only visible when active, so width never shifts */
  .t-nav-link::before { content: "["; color: transparent; }
  .t-nav-link::after { content: "]"; color: transparent; }
  .t-nav-link:hover { color: var(--ink); background: var(--bg-2); }
  .t-nav-link.is-active { color: var(--accent); }
  .t-nav-link.is-active::before,
  .t-nav-link.is-active::after { color: var(--accent); }

  @media (max-width: 560px) {
    .t-bar { flex-direction: column; align-items: flex-start; gap: 10px; padding: 12px 16px; }
    .t-nav { gap: 2px; margin-left: -10px; }
  }
</style>
