---
import { HEADER_LINKS } from "../../consts";
const path = Astro.url.pathname;
const tabs = HEADER_LINKS.map((l, i) => ({ ...l, num: String(i + 1).padStart(2, "0") }));
---

<header class="t-topbar">
  <div class="t-topbar-l">
    <span class="t-dot"></span>
    <span class="t-mono-sm">phoinixi@workstation</span>
    <span class="t-sep">::</span>
    <span class="t-mono-sm t-dim">~/site{path === "/" ? "" : path}</span>
  </div>
  <nav class="t-tabs" aria-label="Primary">
    {tabs.map((t) => {
      const isActive = path === t.url || (t.url !== "/" && path.startsWith(t.url));
      return (
        <a href={t.url} class={`t-tab ${isActive ? "is-active" : ""}`}>
          <span class="t-tab-num">{t.num}</span>
          <span>{t.name.toLowerCase()}</span>
        </a>
      );
    })}
  </nav>
  <div class="t-topbar-r">
    <span class="t-mono-sm t-dim">UTC+1</span>
    <span class="t-sep">·</span>
    <span class="t-mono-sm" id="t-clock">--:--:--</span>
    <span class="t-cursor">_</span>
  </div>
</header>

<script is:inline>
  (function () {
    const el = document.getElementById("t-clock");
    if (!el) return;
    const tick = () => {
      const d = new Date();
      const p = (n) => String(n).padStart(2, "0");
      el.textContent = `${p(d.getHours())}:${p(d.getMinutes())}:${p(d.getSeconds())}`;
    };
    tick();
    setInterval(tick, 1000);
  })();
</script>

<style>
  .t-topbar {
    position: sticky; top: 0; z-index: 50;
    display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
    padding: 12px 24px;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
  }
  .t-topbar-l { display: flex; align-items: center; gap: 10px; min-width: 0; }
  .t-topbar-r { display: flex; align-items: center; gap: 8px; justify-content: flex-end; }
  .t-dot { width: 8px; height: 8px; background: var(--accent); border-radius: 50%; box-shadow: 0 0 12px var(--accent); flex-shrink: 0; }
  .t-tabs { display: flex; gap: 0; border: 1px solid var(--line); }
  .t-tab {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 14px; background: transparent; border: 0; border-right: 1px solid var(--line);
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--ink-2); cursor: pointer; transition: background .15s, color .15s;
    text-decoration: none;
  }
  .t-tab:last-child { border-right: 0; }
  .t-tab:hover { background: var(--bg-2); color: var(--ink); }
  .t-tab.is-active { background: var(--accent); color: #0c0d0c; }
  .t-tab-num { color: var(--dim); }
  .t-tab.is-active .t-tab-num { color: rgba(0,0,0,0.5); }

  @media (max-width: 768px) {
    .t-topbar { grid-template-columns: 1fr auto; padding: 10px 14px; }
    .t-topbar-r { display: none; }
    .t-tabs { font-size: 10px; }
    .t-tab { padding: 5px 8px; }
    .t-tab span:not(.t-tab-num) { display: none; }
  }
</style>
