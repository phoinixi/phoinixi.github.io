---
import { GITHUB_URL, EMAIL } from "../../consts";
---
<footer class="t-foot">
  <span class="t-mono-sm t-dim">© 2026 — Francesco Esposito</span>
  <span class="t-mono-sm t-dim">no cookies · no ads</span>
  <span class="t-mono-sm t-dim">
    <a href={GITHUB_URL} class="t-link">github</a>
    <span class="t-sep">·</span>
    <a href={`mailto:${EMAIL}`} class="t-link">{EMAIL}</a>
  </span>
</footer>
<style>
  .t-foot { display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; padding: 22px 24px; max-width: 1280px; margin: 24px auto 0; border-top: 1px solid var(--line); }
</style>