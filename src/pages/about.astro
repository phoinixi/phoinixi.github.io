---
import Layout from "../layouts/Layout.astro";
import Panel from "../components/layout/Panel.astro";
import { getEntry } from "astro:content";

const aboutPage = await getEntry("pages", "about");
const { Content } = await aboutPage.render();
const updated = aboutPage.data.updatedDate
  ? new Date(aboutPage.data.updatedDate).toISOString().slice(0, 10)
  : null;
---

<Layout title="About | Francesco Esposito">
  <section class="t-page">
    <header class="t-page-head">
      <h1 class="t-section-title">about</h1>
    </header>

    <Panel label="about.md">
      <div class="t-about-grid">
      <aside class="t-rail">
        <dl class="t-rail-list">
          <div class="t-rail-row">
            <dt class="t-mono-sm t-dim">location</dt>
            <dd class="t-mono-sm">Zurich</dd>
          </div>
          <div class="t-rail-row">
            <dt class="t-mono-sm t-dim">since</dt>
            <dd class="t-mono-sm">2005</dd>
          </div>
          <div class="t-rail-row">
            <dt class="t-mono-sm t-dim">stack</dt>
            <dd class="t-mono-sm">TypeScript &amp; friends</dd>
          </div>
          {updated && (
            <div class="t-rail-row">
              <dt class="t-mono-sm t-dim">updated</dt>
              <dd class="t-mono-sm">{updated}</dd>
            </div>
          )}
        </dl>
      </aside>

      <article class="t-about-body prose prose-lg">
        <Content />
      </article>
      </div>
    </Panel>
  </section>
</Layout>

<style>
  .t-page { padding: 8px 0 56px; }
  .t-page-head { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; margin-bottom: 4px; }
  .t-about-grid { display: grid; grid-template-columns: 190px 1fr; gap: 44px; align-items: start; padding-top: 28px; }
  .t-rail { position: sticky; top: 96px; border-left: 1px solid var(--line); padding-left: 16px; }
  .t-rail-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .t-rail-row { display: flex; flex-direction: column; gap: 2px; }
  .t-rail-row dt { margin: 0; }
  .t-rail-row dd { margin: 0; color: var(--ink); }

  .t-about-body { max-width: 64ch; }
  .t-about-body :global(h2) {
    font-family: var(--serif);
    font-size: 22px;
    letter-spacing: -0.01em;
    color: var(--ink);
    border-top: 1px solid var(--line);
    padding-top: 24px;
    margin-top: 44px;
    margin-bottom: 14px;
    font-weight: 500;
  }
  .t-about-body :global(h2:first-child) { border-top: 0; padding-top: 0; margin-top: 0; }
  .t-about-body :global(h3) { font-family: var(--serif); font-weight: 500; font-size: 19px; }
  .t-about-body :global(p) { font-family: var(--serif); font-size: 17px; line-height: 1.7; color: var(--ink-2); }
  .t-about-body :global(ul) { font-family: var(--serif); font-size: 17px; line-height: 1.7; color: var(--ink-2); }
  .t-about-body :global(li) { margin: 6px 0; }
  .t-about-body :global(a) { color: var(--ink); text-decoration: underline; text-decoration-color: var(--line-2); text-underline-offset: 3px; }
  .t-about-body :global(a:hover) { color: var(--accent); text-decoration-color: var(--accent); }

  @media (max-width: 768px) {
    .t-about-grid { grid-template-columns: 1fr; gap: 24px; }
    .t-rail { position: static; border-left: 0; border-top: 1px solid var(--line); padding-left: 0; padding-top: 16px; }
    .t-rail-list { flex-direction: row; flex-wrap: wrap; gap: 14px; }
  }
</style>
