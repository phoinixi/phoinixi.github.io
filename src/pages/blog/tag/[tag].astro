---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../../layouts/Layout.astro";

type BlogPost = CollectionEntry<"blog">;

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const uniqueTags = [
    ...new Set(allPosts.flatMap((post: BlogPost) => post.data.tags || [])),
  ];
  return uniqueTags.map((tag: string) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.params;
const allPosts = await getCollection("blog", ({ data }: { data: BlogPost["data"] }) =>
  data.tags?.includes(tag as string)
);

const sortedPosts: BlogPost[] = allPosts.sort(
  (a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const pageTitle = `Posts tagged with "${tag}"`;
---

<Layout title={pageTitle}>
  <section class="t-page">
    <header class="t-section-head">
      <span class="t-section-num">/01</span>
      <h1 class="t-section-title">TAG · {tag}</h1>
      <span class="t-spacer"></span>
      <a href="/blog" class="t-mono-sm t-link">← all posts</a>
    </header>

    {sortedPosts.length === 0 ? (
      <p class="t-empty">No posts found for this tag.</p>
    ) : (
      <ul class="t-list">
        {sortedPosts.map((post: BlogPost) => {
          const date = post.data.pubDate.toISOString().slice(0, 10);
          return (
            <li class="t-list-row">
              <a href={`/blog/${post.slug}/`} class="t-list-link">
                <span class="t-mono-sm t-dim t-list-date">{date}</span>
                <span class="t-list-title">{post.data.title}</span>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </section>
</Layout>

<style>
  .t-page { padding: 24px 0 56px; }
  .t-list { list-style: none; margin: 0; padding: 0; }
  .t-list-row { border-bottom: 1px solid var(--line); }
  .t-list-link { display: flex; align-items: baseline; gap: 14px; padding: 12px 0; text-decoration: none; color: inherit; transition: padding .15s, background .15s; }
  .t-list-link:hover { padding-left: 8px; background: linear-gradient(90deg, rgba(216,255,62,0.05), transparent 30%); }
  .t-list-date { width: 92px; flex-shrink: 0; color: var(--dim); }
  .t-list-title { font-family: var(--serif); font-size: 19px; color: var(--ink); }
  .t-empty { font-family: var(--serif); color: var(--ink-2); margin-top: 24px; }
</style>
