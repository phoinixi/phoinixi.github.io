---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Panel from "../../../components/layout/Panel.astro";

type BlogPost = CollectionEntry<"blog">;

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const uniqueTags = [
    ...new Set(allPosts.flatMap((post: BlogPost) => post.data.tags || [])),
  ];
  return uniqueTags.map((tag: string) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.params;
const allPosts = await getCollection("blog", ({ data }: { data: BlogPost["data"] }) =>
  data.tags?.includes(tag as string)
);

const sortedPosts: BlogPost[] = allPosts.sort(
  (a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const pageTitle = `Posts tagged with "${tag}"`;
---

<Layout title={pageTitle}>
  <section class="t-page">
    <header class="t-page-head">
      <h1 class="t-section-title">tag: {tag}</h1>
      <span class="t-spacer"></span>
      <a href="/blog" class="t-mono-sm t-link">← all posts</a>
    </header>

    {sortedPosts.length === 0 ? (
      <p class="t-empty">No posts found for this tag.</p>
    ) : (
      <Panel label={`#${tag}`} meta={String(sortedPosts.length)}>
        <ul class="trows">
          {sortedPosts.map((post: BlogPost) => {
            const date = post.data.pubDate.toISOString().slice(0, 10);
            return (
              <li class="trow-item">
                <a href={`/blog/${post.slug}/`} class="trow">
                  <span class="trow-date">{date}</span>
                  <span class="trow-title">{post.data.title}</span>
                  <span class="trow-lead"></span>
                </a>
              </li>
            );
          })}
        </ul>
      </Panel>
    )}
  </section>
</Layout>

<style>
  .t-page { padding: 8px 0 56px; }
  .t-page-head { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; margin-bottom: 4px; }
  .t-empty { font-family: var(--serif); color: var(--ink-2); margin-top: 24px; }

  @media (max-width: 640px) {
    .trow { flex-wrap: wrap; }
    .trow-lead { display: none; }
  }
</style>
