---
import Layout from "../../layouts/Layout.astro";
import Panel from "../../components/layout/Panel.astro";
import { getCollection, type CollectionEntry } from "astro:content";

type BlogPost = CollectionEntry<"blog">;

const posts = (await getCollection("blog")).sort(
  (a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const groups = new Map<string, BlogPost[]>();
for (const p of posts) {
  const y = String(p.data.pubDate.getFullYear());
  if (!groups.has(y)) groups.set(y, []);
  groups.get(y)!.push(p);
}
const years = [...groups.keys()];
---

<Layout title="Blog | Francesco Esposito">
  <section class="t-page">
    <header class="t-page-head">
      <h1 class="t-section-title">writing</h1>
      <span class="t-mono-sm t-dim">{posts.length} entries</span>
    </header>

    {years.map((year) => (
      <Panel label={year} meta={String(groups.get(year)!.length)}>
        <ul class="trows">
          {groups.get(year)!.map((post) => {
            const date = post.data.pubDate.toISOString().slice(5, 10);
            const tag = post.data.tags?.[0];
            return (
              <li class="trow-item">
                <a href={`/blog/${post.slug}`} class="trow">
                  <span class="trow-date trow-date-md">{date}</span>
                  <span class="trow-title">{post.data.title}</span>
                  <span class="trow-lead"></span>
                  {tag && <span class="trow-meta">#{tag}</span>}
                </a>
              </li>
            );
          })}
        </ul>
      </Panel>
    ))}
  </section>
</Layout>

<style>
  .t-page { padding: 8px 0 56px; }
  .t-page-head { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; margin-bottom: 4px; }
  .trow-date-md { width: 56px; }

  @media (max-width: 640px) {
    .trow { flex-wrap: wrap; }
    .trow-lead { display: none; }
  }
</style>
