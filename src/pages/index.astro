---
import Layout from "../layouts/Layout.astro";
import { getCollection, getEntry } from "astro:content";

const heroContent = await getEntry("pages", "home-hero");
const { Content: HeroContent } = await heroContent.render();

const nowEntry = await getEntry("pages", "now").catch(() => null);
const nowItems = nowEntry ? (nowEntry.body.match(/^- (.+)$/gm) || []).slice(0, 4).map(l => l.replace(/^- /, "")) : [];

const allPosts = (await getCollection("blog")).sort((a,b) => +b.data.pubDate - +a.data.pubDate);
const recentPosts = allPosts.slice(0, 4);

const allProjects = (await getCollection("projects")).filter(p => !p.data.draft);
const featured = allProjects.filter(p => p.data.featured).slice(0, 4);
---

<Layout title="Francesco Esposito — Senior Frontend Engineer">
  <section class="t-hero">
    <div class="t-hero-meta">
      <span class="t-tag">/01 INDEX</span>
      <span class="t-mono-sm t-dim">filed under: HUMAN</span>
    </div>
    <div class="t-hero-content">
      <HeroContent />
    </div>
    <div class="t-hero-actions">
      <a class="t-btn t-btn-primary" href="/blog"><span>READ THE BLOG</span><span>→</span></a>
      <a class="t-btn" href="https://mentorcruise.com/mentor/francescoesposito/"><span>BOOK A SESSION</span><span>→</span></a>
      <a class="t-btn-quiet" href="mailto:hey@francescoesposito.dev">hey@francescoesposito.dev</a>
    </div>
  </section>

  <hr class="t-rule" />

  {nowItems.length > 0 && (
    <>
      <section class="t-now">
        <header class="t-section-head">
          <span class="t-section-num">/02</span>
          <h2 class="t-section-title">NOW</h2>
          <span class="t-mono-sm t-dim">— what's running</span>
          <span class="t-spacer"></span>
          <a href="/now" class="t-mono-sm t-link">/now →</a>
        </header>
        <ul class="t-now-list">
          {nowItems.map((item) => {
            const colon = item.indexOf("—");
            const k = colon > -1 ? item.slice(0, colon).trim() : "DOING";
            const v = colon > -1 ? item.slice(colon + 1).trim() : item;
            return (
              <li class="t-now-row">
                <span class="t-now-k">{k.toUpperCase()}</span>
                <span class="t-now-dots"></span>
                <span class="t-now-v">{v}</span>
              </li>
            );
          })}
        </ul>
      </section>
      <hr class="t-rule" />
    </>
  )}

  {featured.length > 0 && (
    <>
      <section class="t-feat">
        <header class="t-section-head">
          <span class="t-section-num">/03</span>
          <h2 class="t-section-title">SELECTED&nbsp;WORK</h2>
          <span class="t-spacer"></span>
          <a class="t-mono-sm t-link" href="/projects">all projects →</a>
        </header>
        <div class="t-feat-grid">
          {featured.map((p, i) => (
            <article class="t-feat-card">
              <div class="t-feat-top">
                <span class="t-mono-sm t-dim">/{String(i+1).padStart(2,"0")}</span>
                <span class="t-mono-sm">{p.data.year}</span>
              </div>
              <h3 class="t-feat-title">{p.data.title}</h3>
              <p class="t-feat-blurb">{p.data.description}</p>
              <div class="t-feat-tags">
                {p.data.tags.map((t) => <span class="t-pill">#{t}</span>)}
              </div>
              <div class="t-feat-foot">
                <a class="t-mono-sm t-link" href={p.data.link}>view ↗</a>
              </div>
            </article>
          ))}
        </div>
      </section>
      <hr class="t-rule" />
    </>
  )}

  <section class="t-recent">
    <header class="t-section-head">
      <span class="t-section-num">/04</span>
      <h2 class="t-section-title">RECENT&nbsp;WRITING</h2>
      <span class="t-spacer"></span>
      <a class="t-mono-sm t-link" href="/blog">archive →</a>
    </header>
    <ul class="t-list">
      {recentPosts.map((p) => {
        const date = p.data.pubDate.toISOString().slice(0,10);
        return (
          <li class="t-list-row">
            <a href={`/blog/${p.slug}`} class="t-list-link">
              <span class="t-mono-sm t-dim t-list-date">{date}</span>
              <span class="t-list-title">{p.data.title}</span>
              <span class="t-spacer"></span>
              {p.data.tags[0] && <span class="t-mono-sm t-tag-sm">#{p.data.tags[0]}</span>}
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</Layout>

<style>
  .t-hero { display: flex; flex-direction: column; gap: 18px; padding: 56px 0; }
  .t-hero-meta { display: flex; align-items: center; gap: 12px; }
  .t-hero-content :global(h1) { font-family: var(--serif); font-weight: 400; font-style: italic; font-size: clamp(56px, 9vw, 132px); line-height: 0.92; letter-spacing: -0.025em; margin: 8px 0 0; color: var(--ink); }
  .t-hero-content :global(p) { font-family: var(--serif); font-size: 22px; line-height: 1.45; color: var(--ink-2); max-width: 64ch; margin: 16px 0 0; }
  .t-hero-actions { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-top: 18px; }
  .t-btn-quiet { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--dim); text-decoration: none; padding-left: 8px; }
  .t-btn-quiet:hover { color: var(--ink); }

  .t-now { padding: 56px 0; }
  .t-now-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .t-now-row { display: grid; grid-template-columns: 140px 1fr auto; gap: 14px; align-items: baseline; }
  .t-now-k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; color: var(--accent); }
  .t-now-dots { border-bottom: 1px dotted var(--line-2); height: 0; align-self: end; margin-bottom: 6px; }
  .t-now-v { font-family: var(--serif); font-size: 22px; color: var(--ink); }

  .t-feat { padding: 56px 0; }
  .t-feat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--line); }
  .t-feat-card { display: flex; flex-direction: column; gap: 12px; padding: 24px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--bg-2); }
  .t-feat-card:nth-child(2n) { border-right: 0; }
  .t-feat-card:hover { outline: 1px solid var(--accent); outline-offset: -1px; }
  .t-feat-top { display: flex; justify-content: space-between; }
  .t-feat-title { font-family: var(--serif); font-weight: 400; font-size: 28px; letter-spacing: -0.01em; margin: 0; color: var(--ink); }
  .t-feat-blurb { font-family: var(--serif); font-size: 16px; line-height: 1.45; color: var(--ink-2); margin: 0; }
  .t-feat-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .t-feat-foot { margin-top: auto; display: flex; align-items: center; padding-top: 8px; border-top: 1px dashed var(--line); }

  .t-recent { padding: 56px 0; }
  .t-list { list-style: none; margin: 0; padding: 0; }
  .t-list-row { border-bottom: 1px solid var(--line); }
  .t-list-link { display: flex; align-items: baseline; gap: 14px; padding: 14px 0; text-decoration: none; color: inherit; transition: padding .15s; }
  .t-list-link:hover { padding-left: 8px; background: linear-gradient(90deg, rgba(216,255,62,0.05), transparent 30%); }
  .t-list-date { width: 92px; flex-shrink: 0; }
  .t-list-title { font-family: var(--serif); font-size: 20px; color: var(--ink); }
  .t-tag-sm { font-family: var(--mono); font-size: 10px; color: var(--accent); letter-spacing: 0.06em; text-transform: lowercase; padding: 1px 6px; border: 1px solid var(--line-2); }

  @media (max-width: 768px) {
    .t-feat-grid { grid-template-columns: 1fr; }
    .t-feat-card { border-right: 0 !important; }
    .t-now-row { grid-template-columns: 100px 1fr; }
    .t-now-row .t-now-dots { display: none; }
    .t-now-v { font-size: 18px; }
  }
</style>