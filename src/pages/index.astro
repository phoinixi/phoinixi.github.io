---
import Layout from "../layouts/Layout.astro";
import Panel from "../components/layout/Panel.astro";
import { getCollection, getEntry } from "astro:content";

const heroContent = await getEntry("pages", "home-hero");
const { Content: HeroContent } = await heroContent.render();

const allPosts = (await getCollection("blog")).sort((a,b) => +b.data.pubDate - +a.data.pubDate);
const recentPosts = allPosts.slice(0, 4);

const allProjects = (await getCollection("projects")).filter(p => !p.data.draft);
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.year.localeCompare(a.data.year))
  .slice(0, 4);
---

<Layout title="Francesco Esposito · Building software, growing engineers">
  <Panel label="whoami">
    <div class="t-hero-content">
      <HeroContent />
    </div>
    <div class="panel-foot">
      <a class="kbd kbd-primary" href="/blog"><span class="kbd-key">↵</span> read the blog</a>
      <a class="kbd" href="https://mentorcruise.com/mentor/francescoesposito/">book a session</a>
      <span class="t-spacer"></span>
      <a class="t-btn-quiet" href="mailto:hey@francescoesposito.dev">hey@francescoesposito.dev</a>
    </div>
  </Panel>

  {featured.length > 0 && (
    <Panel label="selected work" meta={String(featured.length)}>
      <ul class="trows">
        {featured.map((p) => (
          <li class="trow-item">
            <a class="trow" href={p.data.link}>
              <span class="trow-title">{p.data.title}</span>
              <span class="trow-lead"></span>
              <span class="trow-meta">{p.data.year}</span>
            </a>
            <p class="trow-desc">{p.data.description}</p>
            <div class="trow-sub">
              {p.data.tags.map((t) => <span class="t-pill">#{t}</span>)}
              <span class="t-spacer"></span>
              <a class="t-mono-sm t-link" href={p.data.link}>view ↗</a>
            </div>
          </li>
        ))}
      </ul>
      <div class="panel-foot">
        <span class="t-spacer"></span>
        <a class="t-mono-sm t-link" href="/projects">all projects →</a>
      </div>
    </Panel>
  )}

  <Panel label="recent writing">
    <ul class="trows">
      {recentPosts.map((p) => {
        const date = p.data.pubDate.toISOString().slice(0,10);
        return (
          <li class="trow-item">
            <a class="trow" href={`/blog/${p.slug}`}>
              <span class="trow-date">{date}</span>
              <span class="trow-title">{p.data.title}</span>
              <span class="trow-lead"></span>
              {p.data.tags[0] && <span class="trow-meta">#{p.data.tags[0]}</span>}
            </a>
          </li>
        );
      })}
    </ul>
    <div class="panel-foot">
      <span class="t-spacer"></span>
      <a class="t-mono-sm t-link" href="/blog">archive →</a>
    </div>
  </Panel>
</Layout>

<style>
  .t-hero-content :global(h1) { font-family: var(--serif); font-weight: 500; font-size: clamp(38px, 5.5vw, 64px); line-height: 1.04; letter-spacing: -0.02em; margin: 0; color: var(--ink); }
  .t-hero-content :global(p) { font-family: var(--serif); font-size: 19px; line-height: 1.5; color: var(--ink-2); max-width: 60ch; margin: 14px 0 0; }
  .t-btn-quiet { font-family: var(--mono); font-size: 12px; color: var(--dim); text-decoration: none; }
  .t-btn-quiet:hover { color: var(--ink); }

  @media (max-width: 640px) {
    .trow { flex-wrap: wrap; }
    .trow-date { width: auto; }
    .trow-lead { display: none; }
  }
</style>
