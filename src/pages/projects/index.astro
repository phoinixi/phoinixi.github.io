---
import Layout from "../../layouts/Layout.astro";
import Panel from "../../components/layout/Panel.astro";
import { getCollection, type CollectionEntry } from "astro:content";

type Project = CollectionEntry<"projects">;

const all = (await getCollection("projects")).filter((p: Project) => !p.data.draft);

const featured = all
  .filter((p: Project) => p.data.featured)
  .sort((a: Project, b: Project) => b.data.year.localeCompare(a.data.year));

const rest = all
  .filter((p: Project) => !p.data.featured)
  .sort((a: Project, b: Project) => b.data.year.localeCompare(a.data.year));
---

<Layout title="Projects | Francesco Esposito">
  <section class="t-page">
    <header class="t-page-head">
      <h1 class="t-section-title">projects</h1>
      <span class="t-mono-sm t-dim">open-source &amp; experiments · {all.length} total</span>
    </header>

    {featured.length > 0 && (
      <Panel label="featured" meta={String(featured.length)}>
        <ul class="trows">
          {featured.map((p) => (
            <li class="trow-item">
              <a class="trow" href={p.data.link} target="_blank" rel="noopener">
                <span class="trow-title">{p.data.title}</span>
                <span class="trow-lead"></span>
                <span class="trow-meta">{p.data.year}</span>
              </a>
              <p class="trow-desc">{p.data.description}</p>
              <div class="trow-sub">
                {p.data.tags.map((t: string) => <span class="t-pill">#{t}</span>)}
                <span class="t-spacer"></span>
                <a class="t-mono-sm t-link" href={p.data.link} target="_blank" rel="noopener">view ↗</a>
              </div>
            </li>
          ))}
        </ul>
      </Panel>
    )}

    {rest.length > 0 && (
      <Panel label="archive" meta={String(rest.length)}>
        <ul class="trows">
          {rest.map((p) => (
            <li class="trow-item">
              <a class="trow" href={p.data.link} target="_blank" rel="noopener">
                <span class="trow-date">{p.data.year}</span>
                <span class="trow-title">{p.data.title}</span>
                <span class="trow-lead"></span>
                {p.data.tags?.[0] && <span class="trow-meta">#{p.data.tags[0]}</span>}
                <span class="trow-meta">↗</span>
              </a>
              <p class="trow-desc trow-desc-sm">{p.data.description}</p>
            </li>
          ))}
        </ul>
      </Panel>
    )}
  </section>
</Layout>

<style>
  .t-page { padding: 8px 0 56px; }
  .t-page-head { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; margin-bottom: 4px; }
  .trow-desc-sm { font-size: 14px; color: var(--dim); }

  @media (max-width: 640px) {
    .trow { flex-wrap: wrap; }
    .trow-date { width: auto; }
    .trow-lead { display: none; }
  }
</style>
