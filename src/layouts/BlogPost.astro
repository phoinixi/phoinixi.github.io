---
import Layout from "./Layout.astro";
import GiscusComments from "../components/blog/GiscusComments.astro";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

export interface Props {
  title: string;
  description?: string;
  pubDate: string | Date;
  updatedDate?: string | Date;
  heroImage?: string;
  tags?: string[];
  readingTime?: number;
  headings?: Heading[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  readingTime,
  headings = [],
} = Astro.props;

const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const dateStr = new Date(pubDate).toISOString().slice(0, 10);
const updatedStr = updatedDate ? new Date(updatedDate).toISOString().slice(0, 10) : null;
---

<Layout title={title} description={description}>
  <article class="t-post">
    <div class="t-post-grid">
      <div class="t-post-main">
        <header class="t-post-head">
          <div class="t-post-meta">
            <time class="t-mono-sm t-dim" datetime={new Date(pubDate).toISOString()}>{dateStr}</time>
            {readingTime && (
              <>
                <span class="t-sep">·</span>
                <span class="t-mono-sm t-dim">{readingTime} min read</span>
              </>
            )}
            {updatedStr && (
              <>
                <span class="t-sep">·</span>
                <span class="t-mono-sm t-dim">updated {updatedStr}</span>
              </>
            )}
          </div>
          <h1 class="t-post-title">{title}</h1>
          {description && <p class="t-post-lede">{description}</p>}
          {tags.length > 0 && (
            <div class="t-post-tags">
              {tags.map((tag) => (
                <a href={`/blog/tag/${tag}`} class="t-pill">#{tag}</a>
              ))}
            </div>
          )}
        </header>

        {heroImage && (
          <figure class="t-post-hero">
            <img src={heroImage} alt={title} />
          </figure>
        )}

        <div class="t-post-body prose prose-lg">
          <slot />
        </div>

        <GiscusComments />
      </div>

      {tocHeadings.length > 0 && (
        <aside class="t-toc-rail">
          <nav class="t-toc-section">
            <div class="t-mono-sm t-dim t-toc-label">On this page</div>
            <ul class="t-toc-list">
              {tocHeadings.map((h) => (
                <li class={`t-toc-item depth-${h.depth}`}>
                  <a href={`#${h.slug}`} class="t-toc-link">{h.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}
    </div>
  </article>
</Layout>

<style>
  .t-post { padding: 24px 0 56px; }
  .t-post-grid { display: grid; grid-template-columns: minmax(0, 1fr) 260px; gap: 56px; align-items: start; }
  .t-post-main { min-width: 0; }

  .t-post-head { margin-bottom: 32px; padding-bottom: 24px; border-bottom: 1px solid var(--line); }
  .t-post-meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
  .t-post-title {
    font-family: var(--serif); font-weight: 500;
    font-size: clamp(34px, 4.5vw, 48px);
    line-height: 1.08; letter-spacing: -0.02em;
    color: var(--ink); margin: 0;
  }
  .t-post-lede { font-family: var(--serif); font-size: 20px; line-height: 1.5; color: var(--ink-2); max-width: 64ch; margin: 16px 0 0; }
  .t-post-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 18px; }
  .t-post-tags a { text-decoration: none; }

  .t-post-hero { margin: 0 0 32px; border: 1px solid var(--line); }
  .t-post-hero img { display: block; width: 100%; height: auto; }

  .t-post-body { max-width: 72ch; }
  .t-post-body :global(h2) { font-family: var(--serif); font-weight: 500; font-size: 26px; letter-spacing: -0.01em; color: var(--ink); margin-top: 44px; }
  .t-post-body :global(h3) { font-family: var(--serif); font-weight: 500; font-size: 20px; color: var(--ink); margin-top: 32px; }
  .t-post-body :global(p) { font-family: var(--serif); font-size: 17px; line-height: 1.7; color: var(--ink-2); }
  .t-post-body :global(a) { color: var(--ink); text-decoration: underline; text-decoration-color: var(--line-2); text-underline-offset: 3px; }
  .t-post-body :global(a:hover) { color: var(--accent); text-decoration-color: var(--accent); }
  .t-post-body :global(code) { font-family: var(--mono); color: var(--accent); background: var(--bg-2); border: 1px solid var(--line); padding: 1px 5px; }
  .t-post-body :global(pre) { background: var(--bg-2); border: 1px solid var(--line); border-radius: 4px; }
  .t-post-body :global(pre code) { color: var(--ink); border: 0; background: transparent; padding: 0; }
  .t-post-body :global(blockquote) { color: var(--ink-2); border-left: 2px solid var(--line-2); padding-left: 16px; font-style: normal; }
  .t-post-body :global(hr) { border-top: 1px solid var(--line); border-bottom: 0; }
  .t-post-body :global(img) { border: 1px solid var(--line); }

  .t-toc-rail {
    position: sticky; top: 96px;
    border-left: 1px solid var(--line);
    padding-left: 18px;
    display: flex; flex-direction: column; gap: 28px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
  }
  .t-toc-label { display: block; margin-bottom: 10px; color: var(--dim); }
  .t-toc-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; }
  .t-toc-item.depth-3 { padding-left: 14px; }
  .t-toc-link {
    display: block;
    font-family: var(--mono); font-size: 12px;
    color: var(--ink-2); text-decoration: none; line-height: 1.4;
    padding: 2px 0; transition: color .15s;
  }
  .t-toc-link:hover { color: var(--accent); }

  @media (max-width: 1024px) {
    .t-post-grid { grid-template-columns: 1fr; gap: 32px; }
    .t-toc-rail { position: static; max-height: none; border-left: 0; padding-left: 0; padding-top: 24px; border-top: 1px solid var(--line); }
  }
</style>
