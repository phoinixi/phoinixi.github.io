---
import "../styles/global.css";
import BaseHead from "../components/layout/BaseHead.astro";
import Header from "../components/layout/Header.astro";
import StatusBar from "../components/layout/StatusBar.astro";
import Footer from "../components/layout/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

import frauncesUrl from "@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url";
import frauncesItalicUrl from "@fontsource-variable/fraunces/files/fraunces-latin-wght-italic.woff2?url";
import monoUrl from "@fontsource-variable/jetbrains-mono/files/jetbrains-mono-latin-wght-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  ogImage,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={ogImage} />

    <link rel="preload" href={frauncesUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={frauncesItalicUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={monoUrl} as="font" type="font/woff2" crossorigin />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <script
      is:inline
      src="https://cdn.counter.dev/script.js"
      data-id="2234dd9c-82aa-4d38-acf0-7a633d371d46"
      data-utcoffset="2"></script>
  </head>
  <body>
    <Header />
    <StatusBar />
    <main class="t-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .t-main {
    position: relative;
    z-index: 1;
    flex: 1;
    width: 100%;
    padding: 56px 24px;
    max-width: 1280px;
    margin: 0 auto;
  }
  @media (max-width: 768px) {
    .t-main { padding: 32px 18px; }
  }
</style>
